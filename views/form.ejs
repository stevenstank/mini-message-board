<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <h1 class="page-title"><%= title %></h1>

      <form class="form-card" action="/new" method="POST">
        <div class="form-field">
          <label for="messageUser">Author Name</label>
          <input type="text" id="messageUser" name="messageUser" required />
        </div>

        <div class="form-field">
          <label for="messageText">Message Text</label>
          <input type="text" id="messageText" name="messageText" required />
        </div>

        <button class="btn" type="submit">Submit</button>
      </form>
    </main>
    <footer class="site-footer">
      <p>
        made with ❤️ by
        <a href="https://github.com/stevenstank" target="_blank" rel="noopener noreferrer">stevenstank</a>
      </p>
    </footer>
  </body>
</html>
