<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
  </head>
  <body>
    <h1><%= title %></h1>

    <p>
      <a href="/new">Create a New Message</a>
    </p>

    <ul>
      <% messages.forEach((message, index) => { %>
      <li>
        <h2><%= message.user %></h2>
        <p><%= message.text %></p>
        <small><%= message.added %></small>
        <p><a href="/messages/<%= index %>">Open</a></p>
      </li>
      <% }) %>
    </ul>
  </body>
</html>
