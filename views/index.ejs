<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
  </head>
  <body>
    <h1><%= title %></h1>

    <ul>
      <% messages.forEach((message) => { %>
      <li>
        <h2><%= message.user %></h2>
        <p><%= message.text %></p>
        <small><%= message.added %></small>
      </li>
      <% }) %>
    </ul>
  </body>
</html>
